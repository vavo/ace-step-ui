# GetMUSIC Configuration

# Server
PORT=3001
NODE_ENV=development
FRONTEND_PORT=3000

# Database (SQLite)
DATABASE_PATH=./server/data/acestep.db

# ACE-Step API (local - internal only)
ACESTEP_API_URL=http://localhost:8001
# Optional: only set this if you run the legacy/full Gradio UI separately.
# Leave empty for the RunPod uvicorn ACE-Step API server to avoid noisy Gradio probes.
ACESTEP_GRADIO_URL=
ACESTEP_PATH=/workspace/ACE-Step-1.5

# Optional: set this when ffmpeg is installed but not visible to Node's PATH.
# Examples: /usr/bin/ffmpeg or /workspace/ACE-Step-1.5/.venv/bin/ffmpeg
FFMPEG_PATH=

# Storage
AUDIO_DIR=./public/audio

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3001
PASSWORD_RESET_BASE_URL=http://localhost:3000

# JWT Secret (for local session management)
JWT_SECRET=ace-step-ui-local-secret
AUTH_SESSION_DAYS=30
# Single email or comma-separated list. Matching users get admin + unlimited credits.
SUPERADMIN_EMAIL=
SUPERADMIN_EMAILS=

# Product calendar day for credit streaks
PRODUCT_TIME_ZONE=Europe/Bratislava

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Optional: Pexels API Key (for video backgrounds)
# Get a free API key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: Gemini API Key (for AI format actions in the UI)
# Get a key at https://ai.google.dev/
GEMINI_API_KEY=

# Optional: OpenAI API Key (used for AI format actions in the UI)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: OpenAI model and reasoning effort for lyrics and AI format actions
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high

# AI format provider:
# - auto: try OpenAI first, then Gemini fallback
# - openai: force OpenAI (fallback to Gemini if OpenAI key missing)
# - gemini: force Gemini (fallback to OpenAI if Gemini key missing)
FORMAT_PROVIDER=auto
