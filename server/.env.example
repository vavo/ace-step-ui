# ACE-Step UI Configuration

# Server
PORT=3001
NODE_ENV=development

# Database (SQLite)
DATABASE_PATH=./data/acestep.db

# ACE-Step API (local)
ACESTEP_API_URL=http://localhost:8001
ACESTEP_PATH=/workspace/ACE-Step-1.5

# Python fallback generation timeout in milliseconds.
# Fresh pods can spend several minutes loading/downloading ACE-Step models.
GENERATION_TIMEOUT_MS=2700000

# Optional: set this when ffmpeg is installed but not visible to Node's PATH.
# Examples: /usr/bin/ffmpeg or /workspace/ACE-Step-1.5/.venv/bin/ffmpeg
FFMPEG_PATH=/workspace/ACE-Step-1.5/.venv/bin/ffmpeg

# Storage
AUDIO_DIR=./public/audio

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3001

# JWT Secret (for local session management)
JWT_SECRET=ace-step-ui-local-secret
AUTH_SESSION_DAYS=30
SUPERADMIN_EMAIL=

# Product calendar day for credit streaks
PRODUCT_TIME_ZONE=Europe/Bratislava

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Optional: Pexels API Key (for video backgrounds)
# Get a free API key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: Gemini API Key (fallback for AI format actions in the UI)
# Get a key at https://ai.google.dev/
GEMINI_API_KEY=

# Optional: OpenAI API Key (lyrics and AI format actions in the UI)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: OpenAI model and reasoning effort for lyrics and AI format actions
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high

# AI format provider:
# - auto: try OpenAI first, then Gemini fallback
# - openai: force OpenAI
# - gemini: force Gemini
FORMAT_PROVIDER=auto
